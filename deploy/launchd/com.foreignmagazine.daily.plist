<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.foreignmagazine.daily</string>

    <key>WorkingDirectory</key>
    <string>/Users/BGS/Documents/foreign magazine grab daily</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>set -euo pipefail; cd "/Users/BGS/Documents/foreign magazine grab daily"; if [[ -d .venv ]]; then source .venv/bin/activate; fi; exec python3 app.py</string>
